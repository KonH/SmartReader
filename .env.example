# SmartReader — environment secrets template
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is checked in as documentation.
#
# Usage: run.sh sources .env automatically if present.

# ── Telegram API credentials ──────────────────────────────────────────────────
# Required when [telegram] active = true (input) OR [telegram_ui] active = true (bot UI).
# Obtain api_id and api_hash from https://my.telegram.org/apps

# export TELEGRAM_API_ID=12345678
# export TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ── Telegram Bot UI ───────────────────────────────────────────────────────────
# Required when [telegram_ui] active = true in config.toml.
# Create a bot via @BotFather on Telegram and paste the token below.
# Also set controller_usernames in config.toml — an empty list allows ANY user to trigger runs!

# export TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram session string (optional).
# When unset, Telethon prompts for phone number + OTP on first run and
# saves the session to .tmp/telegram.session (gitignored).
# To generate a portable session string instead:
#   python -c "
#   import asyncio; from telethon import TelegramClient; from telethon.sessions import StringSession
#   async def main():
#       c = TelegramClient(StringSession(), API_ID, 'API_HASH')
#       await c.start(); print(await c.session.save())
#   asyncio.run(main())"
# Then paste the output below:
# export TELEGRAM_SESSION=1BQANOTEuAm...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required when the real Summarize implementation is enabled.
# export OPENAI_API_KEY=sk-...
